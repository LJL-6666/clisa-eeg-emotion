__pycache__/
*.pyc
.vscode
daest_run

# ===== Clisa_analysis/（CLISA 方案）本地大文件，不纳入版本管理 =====
# CLISA outputs use one root only: Clisa_analysis/runs/variants/.
# Do not create new tracked outputs under the old results/ root.
Clisa_analysis/results/

# Local FACED runtime inputs are large and should not be committed.
Clisa_analysis/runtime_inputs/Processed_data/*
!Clisa_analysis/runtime_inputs/Processed_data/.gitkeep
Clisa_analysis/runtime_inputs/Processed_data-clisa/*
!Clisa_analysis/runtime_inputs/Processed_data-clisa/.gitkeep

# Large generated arrays/cache from local full runs, including variant runs.
Clisa_analysis/runs/**/data/
Clisa_analysis/runs/**/matplotlib_cache/
Clisa_analysis/runs/**/tmp/
Clisa_analysis/runs/**/hami_vgpu.cache
Clisa_analysis/runs/debug_trace/

# ===== Svm_analysis/（DE+SVM 方案）另有其目录内 .gitignore 兜底 =====
